---
// This is the frontmatter area. You can add variables or JavaScript here later!
const siteTitle = "OnlyJazz";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
  </head>
  <body>
    <header class="hero">
      <img src="/solojazztransparent3.png" alt="My Custom Header Banner" class="hero-image" />
    </header>

    <main class="container">
      <section class="bio">
        <h2>Home of Jazz Aestheticoon</h2>
        <p>
          Here you can find links to all my socials! More coming soon
        </p>
      </section>

      <section class="social-grid">
        
        <a href="https://instagram.com/yourusername" target="_blank" rel="noopener" class="social-card">
          <img src="/instagram.jpg" alt="https://www.instagram.com/jazz.aestheticoon/" />
          <div class="card-label">Instagram</div>
        </a>

        <a href="https://furtrack.com/user/yourusername" target="_blank" rel="noopener" class="social-card">
          <img src="/furtrack2.jpg" alt="https://www.furtrack.com/index/character:jazz_(aestheticoon)" />
          <div class="card-label">Furtrack</div>
        </a>

        <a href="https://t.me/yourusername" target="_blank" rel="noopener" class="social-card">
          <img src="/telegram.jpg" alt="http://t.me/extranuts" />
          <div class="card-label">Telegram</div>
        </a>

      </section>
    </main>
  </body>
</html>

<style>
  /* Base Reset & Fonts */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: system-ui, -apple-system, sans-serif;
    background-color: #1a1a1a;
    color: #f4f4f4;
    line-height: 1.6;
  }

/* Header Image Style */
  .hero {
    width: 100%;
    height: 300px; /* Adjust header height here */
    overflow: hidden;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Ensures the image fills the space nicely */
  }

  /* Main Container */
  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  /* Bio Section */
  .bio {
    text-align: center;
    margin-bottom: 3rem;
    background: #2a2a2a;
    padding: 2rem;
    border-radius: 12px;
  }
  .bio h1 { margin-bottom: 1rem; color: #ffffff; }

  /* Social Links Grid */
  .social-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  /* Individual Social Card */
  .social-card {
    display: block;
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    transition: transform 0.2s ease;
    background: #000;
  }
  .social-card:hover {
    transform: translateY(-5px); /* Cute hover bounce effect */
  }
  .social-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .social-card:hover img {
    opacity: 1;
  }
  
  /* Text over the social photos */
  .card-label {
    position: absolute;
    bottom: 0;
    width: 100%;
    background: rgba(0, 0, 0, 0.7);
    color: white;
    text-align: center;
    padding: 0.75rem;
    font-weight: bold;
    font-size: 1.1rem;
  }
</style>
